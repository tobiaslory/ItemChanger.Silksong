{
    "metadata": [
        {
            "src": [
                {
                    "files": [
                        "ItemChanger.Silksong/ItemChanger.Silksong.csproj"
                    ],
                    "src": ".."
                }
            ],
            "dest": "api",
            "disableGitFeatures": false,
            "disableDefaultFilter": false,
            "properties": {
                "TargetFramework": "netstandard2.1"
            }
        }
    ],
    "build": {
        "xref": [
            "https://learn.microsoft.com/en-us/dotnet/.xrefmap.json",
            "https://normanderwan.github.io/UnityXrefMaps/6000.0/xrefmap.yml"
        ],
        "content": [
            {
                "files": [
                    "api/**.yml",
                    "api/index.md"
                ]
            },
            {
                "files": [
                    "articles/**.md",
                    "articles/**/toc.yml",
                    "toc.yml",
                    "*.md"
                ]
            }
        ],
        "resource": [
            {
                "files": [
                    "images/**"
                ]
            }
        ],
        "overwrite": [
            {
                "files": [
                    "apidoc/**.md"
                ],
                "exclude": [
                    "obj/**",
                    "_site/**"
                ]
            }
        ],
        "dest": "_site",
        "globalMetadataFiles": [],
        "fileMetadataFiles": [],
        "template": [
            "default",
            "modern"
        ],
        "postProcessors": [],
        "markdownEngineName": "markdig",
        "noLangKeyword": false,
        "keepFileLink": false,
        "cleanupCacheHistory": false,
        "disableGitFeatures": false
    }
}